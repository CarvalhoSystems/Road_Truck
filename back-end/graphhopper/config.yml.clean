*ï¿½ï¿½wï¿½3`Hï¿½ï¿½ï¿½jï¿½`ï¿½ï¿½ï¿½jï¿½`ï¿½ï¿½ï¿½jï¿½jï¿½ï¿½jï¿½ 0ï¿½nï¿½ï¿½ï¿½ï¿½ï¿½jï¿½ï¿½ï¿½ï¿½jï¿½ï¿½ï¿½ï¿½jï¿½ï¿½ï¿½ï¿½jï¿½ bundleApiCaller.js.mapï¿½H@ï¿½ï¿½1ï¿½#ï¿½ï¿½ï¿½ï¿½ï¿½yG3graphhopper:
  graph.location: graph-cache

  # Especifica o caminho para o arquivo de mapa .osm.pbf.
  # O arquivo deve estar no diretÃ³rio mapeado para /graphhopper/data no Docker.
  datareader.file: "americas-sul.osm.pbf"
  # Lista de perfis de veÃ­culos a serem ativados.
  # Para habilitar custos de conversÃ£o (penalidade por virar), adicione '|turn_costs=true'.
  graph.flag_encoders: car

  # Valores necessÃ¡rios para os perfis. Para a v0.12, muitos valores sÃ£o implÃ­citos nos flag_encoders.
  # Adicionamos 'road_class' e 'max_speed' como exemplo de valores extras.
  graph.encoded_values: road_class,max_speed

  # Exclui vias nÃ£o relevantes para veÃ­culos motorizados para otimizar o grafo.
  import.osm.ignored_highways: footway,construction,cycleway,path,steps,track'
