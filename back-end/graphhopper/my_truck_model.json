{
  "variables": {
    "vehicle_height": { "type": "Double", "default_value": 0.0 },
    "vehicle_weight": { "type": "Double", "default_value": 0.0 },
    "vehicle_length": { "type": "Double", "default_value": 0.0 }
  },
  "priority": [
    {
      "if": "max_height > 0 && max_height < vehicle_height",
      "multiply_by": "0"
    },
    {
      "if": "max_weight > 0 && max_weight < vehicle_weight",
      "multiply_by": "0"
    },
    {
      "if": "max_length > 0 && max_length < vehicle_length",
      "multiply_by": "0"
    },

    { "if": "road_class == MOTORWAY", "multiply_by": "1.0" },
    { "if": "road_class == TRUNK", "multiply_by": "0.95" },
    {
      "if": "road_class == RESIDENTIAL || road_class == LIVING_STREET",
      "multiply_by": "0.01"
    }
  ],
  "speed": [
    {
      "if": "surface == GRAVEL || surface == SAND",
      "limit_to": "40"
    }
  ],
  "areas": [],
  "distance_influence": 1.0
}
