# Configuração do RoadTruck

## Backend URLs

# 🌐 URL do Backend em Produção (motoristas em todo Brasil)
# Mude isto para seu servidor remoto (Heroku, AWS, Google Cloud, etc)
VITE_BACKEND_URL=https://seu-app-heroku.herokuapp.com/api

# 🏠 URL do Backend em Desenvolvimento (testes locais)
# Deixe como localhost para testes no PC
VITE_BACKEND_LOCAL_URL=http://localhost:8080/api

## Firebase Configuration (para autenticação)

VITE_FIREBASE_API_KEY=seu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=seu_project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=seu_storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id_aqui
VITE_FIREBASE_APP_ID=seu_app_id_aqui

## Outros Serviços (APIs)

VITE_GOOGLE_API_KEY=sua_google_key_aqui
VITE_TOMTOM_API_KEY=sua_tomtom_key_aqui
VITE_HERE_API_KEY=sua_here_key_aqui
