/*
========================
1. Estilos Gerais
========================
 */
body {
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
  color: #333; /* Cor de texto padrão */
  background-color: #f0f4f9; /* Fundo claro para o corpo */
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

a {
  text-decoration: none;
  color: inherit;
}

/* 
============================
2.. Botões login/cadastro 
============================
 */
.btn {
  padding: 10px 20px;
  border-radius: 20px;
  font-weight: 600;
  transition: background-color 0.3s;
  text-transform: uppercase;
  white-space: nowrap;
}

.btn-primary {
  background-color: #2e64e1; /* Azul do botão */
  color: white;
}

.btn-primary:hover {
  background-color: #234fbf;
}

.btn-secondary {
  background-color: #00b36e; /* Verde do botão de 'Assine Agora' */
  color: white;
  padding: 15px 30px;
  border-radius: 8px;
  font-size: 1.1em;
  display: inline-block;
}

.btn-secondary:hover {
  background-color: #00995c;
}

.btn-7day {
  background-color: #00b36e; /* Verde do botão '7-day free trial' */
  color: white;
  padding: 5px 10px;
  font-size: 0.8em;
  text-transform: none;
  font-weight: 400;
}

.btn-security {
  background-color: #00b36e; /* Verde do botão 'SECURTOL' */
  color: white;
  padding: 15px 100px;
  font-size: 1em;
  font-weight: 700;
  border-radius: 10px;
}

/*
===========================
3. CABEÇALHO PRINCIPAL 
===========================
*/
.main-header {
  background-color: #1a1a1a;
  color: white;
  background-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.7),
      rgba(0, 0, 0, 0.4)
    ),
    url("../img/carreta_principal.png");
  background-size: cover;
  background-position: center center;
  padding-bottom: 80px;
  position: relative;
  /* Ajuste para fazer o cabeçalho parecer grande */
  height: 65vh;
}

/*
===================
4. Navbar 
===================
*/
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
}

.logo {
  font-size: 1.5em;
  font-weight: 700;
  color: #00b36e; /* Cor da logo Truck */
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 30px;
  align-items: center;
  margin: 0;
  padding: 0;
}

.nav-links a:hover {
  color: #00b36e;
}

/*
============================
5. Conteúdo do Cabeçalho 
============================
*/
.header-content {
  padding-top: 50px;
  max-width: 750px;
  text-align: left;
  margin: 0;
}

.header-content h1 {
  font-size: 3em;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
  text-align: left;
}

.header-content p {
  font-size: 1.1em;
  margin-bottom: 30px;
}

.header-content .small-text {
  margin-top: 20px;
  font-size: 0.9em;
  color: #aaa;
}

/* 
===================================
6.SEÇÃO DE RECURSOS (4 COLUNAS)
===================================
 */
.features {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  text-align: center;
  margin-top: -100px; /* Sobrepõe o cabeçalho */
  z-index: 10;
  position: relative;
  padding-bottom: 50px;
}

.feature-item {
  background-color: white;
  padding: 10px 20px;
  border-radius: 75px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  width: 22%;
}

.icon-placeholder {
  width: 60px;
  height: 60px;
  margin: 0 auto 15px;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.icon-route {
  background-image: url("../img/gps-cel.png");
}

.icon-gps {
  background-image: url("../img/gps-icon.png");
}

.icon-report {
  background-image: url("../img/report.png");
}

.icon-support {
  background-image: url("../img/support-icon.png");
}

.feature-item h3 {
  font-size: 1em;
  font-weight: 600;
  margin: 0;
}

/* 
==============================
7.SEÇÃO DE DASHBOARD E PREÇOS 
==============================
*/
.dashboard-pricing {
  display: flex;
  gap: 30px;
  align-items: flex-start;
  padding: 50px 20px;
}

.dashboard-preview {
  flex: 1.2;
  background-color: #212529; /* Fundo escuro do dashboard */
  color: white;
  border-radius: 10px;
  padding: 20px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
}

.logo-small {
  font-weight: 700;
  font-size: 0.9em;
  color: #00b36e;
  margin-bottom: 15px;
}

.preview-content {
  background-image: url(../img/rotas_de_caminhao.png);
  background-color: #343a40;
  height: 300px; /* Altura principal para desktop */
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 0.9em;
  text-align: center;
  color: #aaa;
}

/*
==========================================================
8. CONTAINER GERAL DOS PREÇOS (IRMÃO DO DASHBOARD-PREVIEW)
==========================================================
 */
.pricing-container {
  flex: 1;
  display: flex;
  flex-direction: row; /* Lado a lado por padrão */
  gap: 20px;
  align-items: stretch; /* Garante que os cards tenham a mesma altura */
}

.pricing-card {
  background-color: white;
  color: #333;
  padding: 25px;
  border-radius: 20px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  text-align: center;
  position: relative;
  transition: transform 0.3s;
  /* Flexbox para alinhar o botão no final */
  display: flex;
  flex-direction: column;
}

.pricing-card.destaque {
  border: 3px solid #00b36e;
  background-color: #f0fff0;
}

.pricing-card h3 {
  font-size: 1.3em;
  font-weight: 700;
  margin-top: 0;
  margin-bottom: 5px;
  border-radius: 20px;
  color: #2e64e1;
}

.pricing-card .preco {
  font-size: 2.2em;
  font-weight: 800;
  color: #00b36e;
  margin-bottom: 20px;
}

.pricing-card .periodo {
  font-size: 0.7em;
  font-weight: normal;
  color: #6c757d;
}

.pricing-card .beneficio-lista {
  list-style: none;
  padding: 0;
  text-align: left;
  margin-bottom: 20px;
}

.pricing-card .beneficio-lista li {
  padding: 5px 0;
  border-bottom: 1px dashed #eee;
  color: #555;
  display: flex;
  align-items: center;
  font-size: 0.9em;
}

.pricing-card .check-icon {
  color: #00b36e;
  margin-right: 8px;
  font-weight: bold;
}

.pricing-card .badge {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #2e64e1;
  color: white;
  padding: 5px 20px;
  border-bottom-left-radius: 10px;
  border-top-right-radius: 20px;
  font-size: 0.8em;
  font-weight: bold;
}

/* Novo selo para os 7 dias grátis */
.badge-free-trial {
  position: absolute;
  top: 0;
  left: 0;
  background-color: #00b36e; /* Verde para chamar atenção */
  color: white;
  padding: 5px 15px;
  border-top-left-radius: 20px;
  border-bottom-right-radius: 10px;
  font-size: 0.8em;
  font-weight: bold;
}

/* Botão de Assinatura específico para o cartão */
.card-botao {
  width: 100%;
  padding: 5px 0;
  background-color: #2e64e1;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 1em;
  font-weight: 600;
  cursor: pointer;
  transition: background-color 0.3s;
  /* Empurra o botão para o final do card */
  margin-top: auto;
}

.card-btn:hover {
  background-color: #234fbf;
}

.pricing-card.destaque .card-botao {
  background-color: #00b36e;
}

.pricing-card.destaque .card-botao:hover {
  background-color: #00995c;
}

/* Button Fale Conosco */
.btn-primary-fale-conosco {
  background-color: green;
  color: white;
  padding: 15px 30px;
  border-radius: 8px;
  font-size: 1.1em;
  display: inline-block;
}

.btn-primary-fale-conosco:hover {
  background-color: #00995c;
}

/* RODAPÉ */
.main-footer {
  background-color: #212529;
  color: white;
  padding: 30px 0;
}

.footer-links {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-group {
  display: flex;
  align-items: center;
  gap: 15px;
}

.footer-group .faq {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 5px 10px;
  border-radius: 5px;
  font-weight: 700;
  font-size: 0.8em;
}

.footer-group .link-text {
  font-weight: 600;
  font-size: 1.1em;
}

.footer-group .sub-text {
  font-size: 0.8em;
  color: #aaa;
}

/*
=========================
 MODAL NO FINAL DA PAGINA 
=========================
*/
/* O Modal (Fundo escuro que cobre toda a tela) */
.modal {
  display: none; /* ESCONDIDO por padrão */
  position: fixed; /* Fixa o modal na tela */
  z-index: 1000; /* Garante que fique acima de tudo */
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0, 0, 0, 0.6); /* Fundo escuro transparente */
  backdrop-filter: blur(3px); /* Efeito de desfoque sutil (opcional) */
}

/* O conteúdo do Modal (A caixa branca) */
.modal-content {
  background-color: #fefefe;
  margin: 10% auto; /* 10% do topo e centralizado */
  padding: 30px;
  border-radius: 10px;
  width: 90%;
  max-width: 500px; /* Largura máxima para desktop */
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  position: relative;
  animation-name: animatetop;
  animation-duration: 0.4s;
}

/* Animação de entrada */
@keyframes animatetop {
  from {
    top: -300px;
    opacity: 0;
  }
  to {
    top: 0;
    opacity: 1;
  }
}

/* Botão de fechar (o 'x') */
.close-button {
  color: #aaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
  line-height: 1;
}

.close-button:hover,
.close-button:focus {
  color: #333;
  text-decoration: none;
  cursor: pointer;
}

/* Estilos básicos do Formulário dentro do Modal */
.modal-content h2 {
  color: #2e64e1;
  margin-top: 0;
}

.form-group {
  margin-bottom: 15px;
}

.form-group label {
  display: block;
  margin-bottom: 5px;
  font-weight: 600;
}

.form-group input[type="text"],
.form-group input[type="email"],
.form-group textarea {
  width: 100%;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 5px;
  box-sizing: border-box; /* Garante que padding não aumente a largura total */
}

.modal-content .btn-primary {
  width: 100%;
  margin-top: 10px;
}

/* --------------------------------- */
/* ESTILOS RESPONSIVOS (MOBILE)      */
/* --------------------------------- */

/* Tablets e telas menores (até 992px) */
@media (max-width: 992px) {
  .header-content h1 {
    font-size: 2.5em;
  }

  .features {
    flex-wrap: wrap;
    gap: 20px;
  }

  .feature-item {
    width: 45%; /* 2 colunas */
  }

  .dashboard-pricing {
    flex-direction: column; /* Empilha a preview e os preços */
  }
}

/* Tablets - 992px até 1024px */
@media (max-width: 1024px) {
  .navbar {
    padding: 15px 0;
  }

  .nav-links {
    gap: 20px;
  }

  .header-content h1 {
    font-size: 2.2em;
  }

  .features {
    gap: 15px;
  }

  .feature-item {
    width: 23%;
  }

  .dashboard-pricing {
    flex-direction: column;
    padding: 30px 20px;
  }

  .pricing-container {
    flex-direction: row;
    gap: 15px;
  }

  .pricing-card {
    flex: 1;
  }

  .modal-content {
    width: 90%;
    max-width: 500px;
  }
}

/* Tablets menores e celulares grandes - 768px até 992px */
@media (max-width: 992px) {
  .container {
    padding: 0 15px;
  }

  .main-header {
    height: auto;
    padding-bottom: 40px;
    padding-top: 20px;
  }

  .navbar {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
  }

  .logo {
    font-size: 1.2em;
  }

  .nav-links {
    display: none;
  }

  .nav-links.mobile-open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    background-color: #1a1a1a;
    padding: 20px;
    gap: 15px;
    z-index: 999;
  }

  .header-content {
    text-align: center;
    padding-top: 30px;
    max-width: 100%;
  }

  .header-content h1 {
    font-size: 1.8em;
    line-height: 1.3;
  }

  .header-content p {
    font-size: 0.95em;
  }

  .btn-secondary {
    padding: 12px 20px;
    font-size: 0.95em;
  }

  .features {
    margin-top: 30px;
    flex-direction: column;
    gap: 15px;
    padding: 20px 0;
  }

  .feature-item {
    width: 90%;
    margin: 0 auto;
    padding: 15px 10px;
  }

  .feature-item h3 {
    font-size: 0.9em;
  }

  .dashboard-pricing {
    flex-direction: column;
    gap: 20px;
    padding: 30px 10px;
  }

  .dashboard-preview {
    flex: 1;
    padding: 15px;
  }

  .preview-content {
    height: 200px;
  }

  .pricing-container {
    flex: 1;
    flex-direction: column;
    gap: 15px;
  }

  .pricing-card {
    width: 100%;
    padding: 20px;
  }

  .pricing-card h3 {
    font-size: 1.1em;
  }

  .pricing-card .preco {
    font-size: 1.8em;
  }

  .pricing-card .beneficio-lista {
    font-size: 0.85em;
  }

  .footer-links {
    flex-direction: column;
    gap: 15px;
  }

  .footer-group {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .modal-content {
    width: 95%;
    margin: 50% auto;
    padding: 20px;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group textarea {
    font-size: 16px;
  }

  .btn-primary-fale-conosco {
    padding: 12px 20px;
    font-size: 0.95em;
    width: 100%;
  }
}

/* Celulares pequenos e médios - até 768px */
@media (max-width: 768px) {
  .container {
    padding: 0 10px;
  }

  .main-header {
    height: auto;
    padding-bottom: 30px;
    padding-top: 15px;
  }

  .navbar {
    flex-direction: row;
    justify-content: space-between;
    padding: 10px 0;
  }

  .logo {
    font-size: 1.1em;
  }

  .nav-links {
    display: none;
  }

  .btn.btn-primary {
    padding: 8px 12px;
    font-size: 0.9em;
  }

  .header-content h1 {
    font-size: 1.6em;
    margin-bottom: 15px;
  }

  .header-content p {
    font-size: 0.9em;
    margin-bottom: 15px;
  }

  .btn-secondary {
    padding: 10px 15px;
    font-size: 0.9em;
  }

  .features {
    margin-top: 20px;
    flex-direction: column;
    gap: 10px;
  }

  .feature-item {
    width: 100%;
    padding: 12px 8px;
    border-radius: 50px;
  }

  .feature-item h3 {
    font-size: 0.85em;
  }

  .icon-placeholder {
    width: 45px;
    height: 45px;
    margin: 0 auto 10px;
  }

  .dashboard-pricing {
    flex-direction: column;
    padding: 20px 0;
  }

  .dashboard-preview {
    padding: 15px;
  }

  .preview-content {
    height: 250px;
  }

  .pricing-container {
    flex-direction: column;
    gap: 15px;
  }

  .pricing-card {
    padding: 15px;
  }

  .pricing-card h3 {
    font-size: 1em;
  }

  .pricing-card .preco {
    font-size: 1.6em;
  }

  .pricing-card .beneficio-lista {
    font-size: 0.8em;
  }

  .pricing-card .beneficio-lista li {
    padding: 3px 0;
  }

  .card-botao {
    padding: 8px 0;
    font-size: 0.85em;
  }

  .modal-content {
    width: 95%;
    margin: 40% auto;
    padding: 15px;
  }

  .close-button {
    font-size: 24px;
  }

  .form-group {
    margin-bottom: 12px;
  }

  .form-group label {
    font-size: 0.8em;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group textarea {
    padding: 8px;
    font-size: 16px;
  }

  .footer-links {
    flex-direction: column;
    gap: 15px;
    align-items: center;
  }

  .footer-group {
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .btn-primary-fale-conosco {
    padding: 12px 15px;
    font-size: 0.9em;
    width: 100%;
  }
}

/* Celulares pequenos - até 480px */
@media (max-width: 480px) {
  .container {
    padding: 0 8px;
  }

  body {
    font-size: 14px;
  }

  .main-header {
    height: auto;
    padding-bottom: 25px;
    padding-top: 12px;
  }

  .navbar {
    flex-direction: row;
    justify-content: space-between;
    padding: 8px 0;
    gap: 5px;
  }

  .logo {
    font-size: 0.95em;
    font-weight: 700;
  }

  .nav-links {
    display: none;
  }

  .btn.btn-primary {
    padding: 7px 10px;
    font-size: 0.75em;
    white-space: normal;
    word-break: break-word;
  }

  .header-content {
    text-align: center;
    padding-top: 20px;
  }

  .header-content h1 {
    font-size: 1.4em;
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .header-content p {
    font-size: 0.8em;
    margin-bottom: 12px;
  }

  .small-text {
    font-size: 0.7em !important;
  }

  .btn-secondary {
    padding: 8px 12px;
    font-size: 0.8em;
  }

  .features {
    margin-top: 15px;
    flex-direction: column;
    gap: 8px;
    padding: 0;
  }

  .feature-item {
    width: 100%;
    padding: 10px;
    border-radius: 40px;
  }

  .feature-item h3 {
    font-size: 0.75em;
    margin: 0;
  }

  .icon-placeholder {
    width: 35px;
    height: 35px;
    margin: 0 auto 8px;
  }

  .dashboard-pricing {
    flex-direction: column;
    gap: 15px;
    padding: 15px 0;
  }

  .dashboard-preview {
    width: 100%;
    padding: 10px;
  }

  .logo-small {
    font-size: 0.8em;
    margin-bottom: 10px;
  }

  .preview-content {
    height: 150px;
    font-size: 0.8em;
  }

  .pricing-container {
    flex-direction: column;
    gap: 10px;
  }

  .pricing-card {
    padding: 12px;
  }

  .pricing-card h3 {
    font-size: 0.95em;
    margin-bottom: 5px;
  }

  .pricing-card .preco {
    font-size: 1.4em;
    margin-bottom: 10px;
  }

  .pricing-card .periodo {
    font-size: 0.6em;
  }

  .pricing-card .beneficio-lista {
    font-size: 0.7em;
    margin-bottom: 10px;
  }

  .pricing-card .beneficio-lista li {
    padding: 2px 0;
    font-size: 0.7em;
  }

  .pricing-card .check-icon {
    margin-right: 5px;
  }

  .card-botao {
    padding: 6px 0;
    font-size: 0.75em;
    margin-top: 8px;
  }

  .badge {
    padding: 3px 12px;
    font-size: 0.65em;
  }

  .badge-free-trial {
    padding: 3px 10px;
    font-size: 0.65em;
  }

  .main-footer {
    padding: 20px 0;
  }

  .footer-links {
    flex-direction: column;
    gap: 12px;
  }

  .footer-group {
    gap: 5px;
  }

  .footer-group .faq {
    font-size: 0.65em;
    padding: 3px 8px;
  }

  .footer-group .link-text {
    font-size: 0.9em;
  }

  .footer-group .sub-text {
    font-size: 0.7em;
  }

  .modal-content {
    width: 95%;
    margin: 30% auto;
    padding: 12px;
  }

  .modal-content h2 {
    font-size: 1.1em;
    margin-bottom: 10px;
  }

  .modal-content p {
    font-size: 0.85em;
    margin-bottom: 10px;
  }

  .close-button {
    font-size: 20px;
  }

  .form-group {
    margin-bottom: 10px;
  }

  .form-group label {
    font-size: 0.75em;
    margin-bottom: 4px;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group textarea {
    padding: 6px;
    font-size: 16px;
    border-radius: 4px;
  }

  .modal-content .btn-primary {
    padding: 8px 0;
    font-size: 0.8em;
    margin-top: 8px;
  }

  .btn-primary-fale-conosco {
    padding: 10px 12px;
    font-size: 0.8em;
    width: 100%;
    border-radius: 6px;
  }
}
